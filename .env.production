# Used by `npm run build` (and therefore the Capacitor/Android build).
# The APK runs on a separate device, so it CANNOT use localhost — point this
# at your Cloudflare tunnel URL (or eventually a real hosted backend).
#
# Update this every time your tunnel URL changes, then rebuild:
#   npm run build && npx cap copy
# VITE_API_BASE_URL=https://visiting-womanhood-vagabond.ngrok-free.dev

VITE_API_BASE_URL=https://api.rejam.click

